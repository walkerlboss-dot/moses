                        point3f[] points = [(-0.035, -0.035, -0.12), (0.035, -0.035, -0.12), (0.035, 0.035, -0.12), (-0.035, 0.035, -0.12), (-0.035, -0.035, 0), (-0.035, 0.035, 0), (0.035, 0.035, 0), (0.035, -0.035, 0)]
