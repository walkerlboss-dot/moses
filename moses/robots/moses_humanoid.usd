                                float physics:mass = 1.2
                            }
                        }
                    }
                }

                # --------------------------------------------------------------
                # RIGHT LEG (7 DOF) — mirror of left
                # --------------------------------------------------------------
                def RevoluteJoint "right_hip_yaw"
