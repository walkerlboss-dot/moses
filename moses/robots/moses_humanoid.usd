                uniform token physics:axis = "Z"
                float physics:lowerLimit = -1.57
                float physics:upperLimit = 1.57
                float physics:drive:stiffness = 60.0
                float physics:drive:damping = 4.0
                float physics:drive:maxForce = 100.0
                rel physics:body0 = </MosesHumanoid/Robot/torso>
                rel physics:body1 = </MosesHumanoid/Robot/head>
            }

            def Xform "head"
            {
                float3 xformOp:translate = (0, 0, 0.30)
                uniform token[] xformOpOrder = ["xformOp:translate"]

                def Mesh "head_visual"
                {
                    float3[] extent = [(-0.08, -0.08, -0.10), (0.08, 0.08, 0.10)]
