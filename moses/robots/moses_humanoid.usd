                }

                # Camera attachment point
                def Xform "camera"
                {
                    float3 xformOp:translate = (0.10, 0, 0.05)
                    uniform token[] xformOpOrder = ["xformOp:translate"]
                }
            }

            # ------------------------------------------------------------------
            # LEFT ARM (7 DOF)
            # ------------------------------------------------------------------
            def RevoluteJoint "left_shoulder_pitch"
            {
                uniform token physics:axis = "Y"
                float physics:lowerLimit = -2.356
                float physics:upperLimit = 2.356
                float physics:drive:stiffness = 40.0
                float physics:drive:damping = 2.5
                float physics:drive:maxForce = 150.0
                rel physics:body0 = </MosesHumanoid/Robot/torso>
                rel physics:body1 = </MosesHumanoid/Robot/left_upper_arm>
            }

            def Xform "left_upper_arm"
            {
                float3 xformOp:translate = (-0.20, 0, 0.15)
                uniform token[] xformOpOrder = ["xformOp:translate"]

                def Mesh "left_upper_arm_visual"
                {
                    float3[] extent = [(-0.04, -0.04, -0.15), (0.04, 0.04, 0.0)]
                    point3f[] points = [(-0.04, -0.04, -0.15), (0.04, -0.04, -0.15), (0.04, 0.04, -0.15), (-0.04, 0.04, -0.15), (-0.04, -0.04, 0), (-0.04, 0.04, 0), (0.04, 0.04, 0), (0.04, -0.04, 0)]
