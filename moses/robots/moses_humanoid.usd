                            uniform token physics:axis = "Y"
                            float physics:lowerLimit = -0.785
                            float physics:upperLimit = 0.785
                            float physics:drive:stiffness = 80.0
                            float physics:drive:damping = 5.0
                            float physics:drive:maxForce = 200.0
                            rel physics:body0 = </MosesHumanoid/Robot/right_shin>
                            rel physics:body1 = </MosesHumanoid/Robot/right_foot>
                        }

                        def Xform "right_foot"
                        {
                            float3 xformOp:translate = (0, 0, -0.20)
                            uniform token[] xformOpOrder = ["xformOp:translate"]

                            def Mesh "right_foot_visual"
                            {
                                float3[] extent = [(-0.08, -0.08, -0.03), (0.05, 0.08, 0.0)]
                                point3f[] points = [(-0.08, -0.08, -0.03), (0.05, -0.08, -0.03), (0.05, 0.08, -0.03), (-0.08, 0.08, -0.03), (-0.08, -0.08, 0), (-0.08, 0.08, 0), (0.05, 0.08, 0), (0.05, -0.08, 0)]
                                color3f[] primvars:displayColor = [(0.3, 0.3, 0.3)]
                            }
                            def PhysicsRigidBodyAPI "right_foot_physics"
