                            point3f[] points = [(-0.05, -0.05, -0.20), (0.05, -0.05, -0.20), (0.05, 0.05, -0.20), (-0.05, 0.05, -0.20), (-0.05, -0.05, 0), (-0.05, 0.05, 0), (0.05, 0.05, 0), (0.05, -0.05, 0)]
                            color3f[] primvars:displayColor = [(0.8, 0.2, 0.2)]
                        }
                        def PhysicsRigidBodyAPI "right_shin_physics"
